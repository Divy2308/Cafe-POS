# Flask Secret Key (Required for sessions)
SECRET_KEY=pos-cafe-generate-a-long-random-string-here

# Razorpay Integration
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Resend Email Integration
RESEND_API_KEY=
# Use a verified sender from your own domain for production delivery.
RESEND_FROM=POS Cafe <onboarding@your-domain.com>
# Optional alias used by some Resend examples
EMAIL_FROM=POS Cafe <onboarding@your-domain.com>

# Optional SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=1
